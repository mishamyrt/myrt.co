---
type TextVariant = "text-s" | "text-m";
type HeadingVariant = "heading-xs" | "heading-s" | "heading-m" | "heading-l";

export type Props<T extends TagName = "p"> = HTMLElementProps<T> & {
  as?: T;
  variant?: TextVariant | HeadingVariant;
  children?: any;
  color?: "inherit" | "primary" | "secondary" | "tertiary";
  id?: string;
  class?: string;
};

const {
  as = "p",
  variant = "text-m",
  color = "inherit",
  class: className,
  id,
  ...rest
} = Astro.props;

const Tag = as;
---

<Tag
  id={id}
  class:list={["typography", `variant-${variant}`, `color-${color}`, className]}
  {...rest as any}><slot /></Tag
>

<style lang="scss">
  .typography {
    font-family: var(--typography-font-family-sans-serif);
    font-variant-ligatures: common-ligatures;
    font-feature-settings: "liga";
    margin: 0;

    & :global(a) {
      color: inherit;
    }

    &.variant {
      &-text-s {
        font: var(--typography-text-s);
        letter-spacing: var(--typography-text-s_spacing);
      }

      &-text-m {
        font: var(--typography-text-m);
        letter-spacing: var(--typography-text-m_spacing);
      }

      &-text-m + &-text-m {
        margin-top: var(--space-m);
      }

      &-heading-xs {
        font: var(--typography-heading-xs);
        letter-spacing: var(--typography-heading-xs_spacing);
      }

      &-heading-s {
        font: var(--typography-heading-s);
        letter-spacing: var(--typography-heading-s_spacing);
      }

      &-heading-m {
        font: var(--typography-heading-m);
        letter-spacing: var(--typography-heading-m_spacing);
        margin: 0 0 calc(var(--space-m) + 3px);
      }

      &-heading-l {
        font: var(--typography-heading-l);
        letter-spacing: var(--typography-heading-l_spacing);
        margin: -1px 0 calc(var(--space-m) + 1px);
      }
    }

    /* & + p.variant-text,
    & + p.variant-text {
      margin-top: 1em;
    } */

    &.color-inherit {
      color: inherit;
    }
    &.color-primary {
      color: var(--color-content-primary);
    }
    &.color-secondary {
      color: var(--color-content-secondary);
    }
    &.color-tertiary {
      color: var(--color-content-tertiary);
    }
  }

  :global(a):hover.typography,
  .typography :global(a):hover {
    color: var(--color-link_hover);
    text-decoration-color: var(--color-link-underline_hover);
  }
</style>
