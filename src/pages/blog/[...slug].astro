---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("blog");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<Layout title={`Миша Хрустик — ${article.data.title}`}>
  <article>
    <h1>{article.data.title}</h1>
    <Content />
  </article>
</Layout>

<style>
  article {
    font-family: var(--typography-font-family-sans-serif);

    :global(p) {
      font: var(--typography-text);
      letter-spacing: var(--typography-text_spacing);
      max-width: var(--size-layout-content-narrow);
      margin: 0 auto;
    }

    :global(p + p) {
      margin-top: 8px;
    }

    :global(h1) {
      font: var(--typography-heading-xl);
      letter-spacing: var(--typography-heading-xl_spacing);
      margin: 0 auto 16px;
      max-width: var(--size-layout-content-narrow);
    }

    :global(h2),
    :global(h3) {
      font: var(--typography-heading);
      letter-spacing: var(--typography-heading_spacing);
      font-weight: 600;
      margin: 24px auto 8px;
      max-width: var(--size-layout-content-narrow);
      position: relative;
      top: -1px;
    }
  }
</style>
