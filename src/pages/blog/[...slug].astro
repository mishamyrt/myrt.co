---
import Layout from "../../layouts/Layout.astro";
import Typography from "../../components/Typography.astro";
import { getCollection, render } from "astro:content";
import { formatCyrillicDate, parseFullDate } from "../../utils/date";

export async function getStaticPaths() {
  const articles = await getCollection("blog");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const date = article.data.publishedAt
    ? formatCyrillicDate(parseFullDate(article.data.publishedAt))
    : null;
const { Content } = await render(article);
---

<Layout title={`Миша Хрустик — ${article.data.title}`}>
  <article>
    <h1>{article.data.title}</h1>
    <Content />
    {date && (
      <time datetime="2026-07-10">
        <Typography class="date" color="tertiary" variant="text-m">Опубликовано {date}</Typography>
      </time>
    )}
  </article>
</Layout>

<style>
  .date {
    margin-top: var(--space-m);
  }

  article {
    font-family: var(--typography-font-family-serif);

    .img-container {
      margin: calc(var(--space-l) + 1px) 0 var(--space-l);
    }

    .img-caption {
      font-family: var(--typography-text-s);
      letter-spacing: var(--typography-text-s_spacing);
      color: var(--color-content-tertiary);
      max-width: var(--size-layout-content-narrow);
      display: block;
      margin-top: 2px;
    }

    :global(.img-wrapper) {
      position: relative;
      max-width: 100%;

      :global(img) {
        position: absolute;
        width: 100%;
        height: 100%;
      }
    }

    :global(p) {
      color: var(--color-content-secondary);
      font: var(--typography-text-m);
      letter-spacing: var(--typography-text-m_spacing);
      max-width: var(--size-layout-content-narrow);
      margin: var(--space-m) 0 0;
    }

    :global(h1) {
      font: var(--typography-heading-l);
      letter-spacing: var(--typography-heading-l_spacing);
      margin: -1px 0 calc(var(--space-m) + 1px);
      color: var(--color-content-primary);
      max-width: var(--size-layout-content-narrow);
    }

    :global(h2) {
      font: var(--typography-heading-m);
      letter-spacing: var(--typography-heading-m_spacing);
      margin: calc(var(--space-xl) - 3px) 0 calc(var(--space-s) + 3px);
      max-width: var(--size-layout-content-narrow);
      color: var(--color-content-primary);
    }

    :global(pre + h2) {
      margin-top: calc(var(--space-xl) - 1px);
    }

    :global(ul) {
      margin: 0;
      max-width: var(--size-layout-content-narrow);
      list-style-type: none;
    }

    :global(li) {
      color: var(--color-content-secondary);
      font: var(--typography-text-m);
      margin-top: var(--space-s);
    }

    :global(blockquote) {
      padding-left: var(--space-xl);
      max-width: var(--size-layout-content-narrow);
      margin: var(--space-m) 0;
    }

    :global(a) {
      color: var(--color-content-link);
      text-decoration: none;
    }

    :global(a:hover) {
      text-decoration: underline;
    }

    :global(a code) {
      color: var(--color-content-link);
    }

  :global(code) {
    font: var(--typography-code-m);
    color: var(--color-content-primary);
    background-color: var(--color-background-secondary);
  }

  :global(p code),
  :global(ul code),
  :global(ol code) {
    position: relative;
    background-color: var(--color-background-secondary);
    padding: 0 2px;
    margin: 0 -2px;
    border-radius: 3px;
  }

  :global(pre) {
    font: var(--typography-code-m);
    width: calc(var(--size-layout-content-narrow) + 40px);
    margin: calc(var(--space-m) + 4px) 0px calc(var(--space-m) + 2px) -20px;
    padding: 15px 20px;
    border-radius: 8px;
    background-color: var(--color-background-secondary) !important;
  }

  :global(table) {
    font: var(--typography-text-m);
    color: var(--color-content-secondary);
    margin: var(--space-m) 0 0;
    border-collapse: collapse;
  }

  :global(table + h2) {
    margin-top: calc(var(--space-xl) - 12px);
  }

  :global(table .line) {
    height: 27px;
    display: inline-block;
  }

  :global(th) {
    font: var(--typography-heading-s);
    text-align: left;
    padding: 0;
    line-height: 27px;
  }

  :global(tr) {
    line-height: 27px;
  }

  :global(th),
  :global(td) {
    padding: 0 var(--space-m) var(--space-s) 0;
  }
</style>
