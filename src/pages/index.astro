---
import Layout from "../layouts/Layout.astro";
import Typography from "../components/Typography.astro";
import Experience from "../components/Experience.astro";
import { getCollection } from "astro:content";

const experience = await getCollection("experience");

function parseDate(s: string): number {
  const [month, year] = s.split(".").map((i) => parseInt(i, 10));
  const date = new Date();
  date.setFullYear(year, month);
  return date.getTime();
}

const places = experience.toSorted(
  (a, b) => parseDate(b.data.from) - parseDate(a.data.from),
);
---

<Layout title="Миша Хрустик">
  <div class="hero">
    <img
      class="hero-avatar honey"
      data-effect="slide"
      data-hold="700"
      data-duration="600"
      data-left="32px"
      src="/avatar@2x.jpg"
      alt="Фотография Миши Хрустика"
    />
    <div class="honey" data-effect="slide" data-up="32px">
      <Typography variant="heading-l" as="h1" color="primary">
        Миша Хрустик,<br />тимлид
      </Typography>
      <Typography color="secondary">
        Руковожу кроссфункциональными командами. Выстраиваю процессы так,
        что задачи перестают переезжать между спринтами. Участвую в найме,
        онбординге и развитии инженеров.
      </Typography>
      <Typography color="secondary">
        Занимаюсь консультациями по разработке и проектным проведением
        собеседований. Пишите мне в <a href="https://t.me/mishamyrt">телеграм</a
        > или на <a href="mailto:misha@myrt.co">почту</a>.
      </Typography>
    </div>
  </div>
  <div class="experienceContainer">
    {places.map((place) => <Experience place={place} />)}
  </div>
</Layout>

<style>
  .hero {
    max-width: var(--size-layout-content-narrow);
    position: relative;
  }

  .hero-avatar {
    --avatar-size: 54px;

    width: var(--avatar-size);
    height: var(--avatar-size);
    position: absolute;
    left: calc((var(--avatar-size) * -1) - var(--space-layout-aside));
    top: calc((var(--avatar-size) * -1) / 9);
    border-radius: 50%;
  }

  .experienceContainer {
    margin-top: 42px;
  }

  @media (max-width: 873px) {
    .hero-avatar {
      display: none;
    }

    .experienceContainer {
      margin-top: 69px;
    }
  }
</style>
