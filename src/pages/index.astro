---
import Layout from "../layouts/Layout.astro";
import Hero from "../blocks/Hero.astro";
import Experience from "../blocks/Experience.astro";

function parseDate(s: string): number {
  const [month, year] = s.split(".").map((i) => parseInt(i, 10));
  const date = new Date();
  date.setFullYear(year, month);
  return date.getTime();
}

function sortDesc(a: any, b: any): number {
  return parseDate(b.frontmatter.from) - parseDate(a.frontmatter.from);
}

const experienceMatches = import.meta.glob("../content/experience/*.md", {
  eager: true,
});
const experience = Object.values(experienceMatches);
---

<Layout title="Миша Хрустик">
  <Hero />
  <Experience items={experience} />
</Layout>
